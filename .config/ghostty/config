theme = Catppuccin Mocha
font-family = Lilex Nerd Font Mono
font-family = RobotoMono Nerd Font Mono
font-size = 12
font-feature = -calt,-liga,-dlig

background-opacity = 1
unfocused-split-opacity = 0.8

cursor-style = bar
shell-integration-features = cursor,no-title
scrollback-limit = 10000000
bold-is-bright = true

window-padding-x = 4
window-padding-y = 4

# centers text when window doesn't match cell grid
window-padding-balance = true
window-padding-color = background

window-height = 40
window-width = 140

keybind = alt+shift+minus=new_split:down
keybind = alt+shift+plus=new_split:right
keybind = ctrl+shift+w=close_surface

gtk-titlebar-style = tabs
